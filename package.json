{
  "name": "sizzling-hot-products",
  "version": "1.0.0",
  "description": "Calculates Bunnings sizzling hot products from order and product JSON inputs.",
  "main": "expo/AppEntry",
  "scripts": {
    "build": "tsc -p tsconfig.node.json",
    "start": "expo start",
    "cli": "npm run build && node dist/src/server/cli.js",
    "api": "npm run build && node dist/src/server/graphql/server.js",
    "ios": "expo start --ios",
    "android": "expo start --android",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm test",
    "prepare": "husky",
    "test": "jest"
  },
  "keywords": [
    "bunnings",
    "orders",
    "products"
  ],
  "author": "",
  "license": "UNLICENSED",
  "dependencies": {
    "expo": "^54.0.0",
    "expo-constants": "~18.0.13",
    "expo-status-bar": "^3.0.0",
    "graphql": "^16.8.1",
    "react": "^19.1.0",
    "react-native": "^0.81.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.0.0",
    "@types/node": "^20.11.30",
    "@types/react": "^19.1.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-expo": "^54.0.0",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.3",
    "typescript": "^5.4.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=18"
  }
}
