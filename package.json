{
  "name": "sizzling-hot-products",
  "version": "1.0.0",
  "description": "Calculates Bunnings sizzling hot products from order and product JSON inputs.",
  "main": "expo/AppEntry",
  "scripts": {
    "build": "tsc -p tsconfig.node.json",
    "start": "expo start",
    "cli": "npm run build && node dist/src/cli.js",
    "api": "npm run build && node dist/src/graphql/server.js",
    "ios": "expo start --ios",
    "android": "expo start --android",
    "test": "jest"
  },
  "keywords": [
    "bunnings",
    "orders",
    "products"
  ],
  "author": "",
  "license": "UNLICENSED",
  "dependencies": {
    "expo": "^54.0.0",
    "expo-constants": "~18.0.13",
    "expo-status-bar": "^3.0.0",
    "graphql": "^16.8.1",
    "react": "^19.1.0",
    "react-native": "^0.81.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.0.0",
    "@types/node": "^20.11.30",
    "@types/react": "^19.1.0",
    "jest": "^29.7.0",
    "jest-expo": "^54.0.0",
    "typescript": "^5.4.2"
  },
  "jest": {
    "preset": "jest-expo",
    "watchman": false,
    "setupFilesAfterEnv": [
      "<rootDir>/test/setup/jest.setup.ts"
    ],
    "testMatch": [
      "**/test/**/*.test.ts",
      "**/test/**/*.test.tsx"
    ]
  },
  "engines": {
    "node": ">=18"
  }
}
